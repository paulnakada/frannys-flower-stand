// firestore.rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isAdminUser() {
      // Only Firebase-authenticated users (magic link admins) have a UID
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users (admin profiles only) ─────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ── Posts ────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Anyone (even unauthenticated) can read non-deleted posts — no login required
      allow read: if resource.data.isDeleted == false;
      // Only admin can create/update posts
      allow create: if isAdminUser();
      allow update: if isAdminUser();
      allow delete: if false;

      // ── Likes ──────────────────────────────────────────────────────────────
      // Likes use deviceId (a string) as the doc ID — no auth required.
      // We can't validate identity without auth, but that's acceptable for likes.
      match /likes/{deviceId} {
        allow read: if true;
        allow write: if true;  // Anonymous likes — trust the client
      }

      // ── Comments ───────────────────────────────────────────────────────────
      match /comments/{commentId} {
        // Public read: only approved, non-deleted comments
        allow read: if resource.data.status == 'approved' &&
                       resource.data.isDeleted == false;
        // Admin reads all
        allow read: if isAdminUser();

        // Anyone can create a comment (status must be 'pending', no auth needed)
        allow create: if request.resource.data.status == 'pending' &&
                         request.resource.data.isDeleted == false;

        // Only admin can update (approve / reject)
        allow update: if isAdminUser();
        allow delete: if false;
      }
    }
  }
}
