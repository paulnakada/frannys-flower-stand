{
  "expo": {
    "name": "Franny's Flower Stand",
    "slug": "frannys-flower-stand",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "frannysflower",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.schoolpages.frannysflower",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.schoolpages.frannysflower",
      "adaptiveIcon": {
        "backgroundColor": "#FBF7F2"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Franny's Flower Stand to access your photos.",
          "cameraPermission": "Allow Franny's Flower Stand to access your camera."
        }
      ],
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "11ae681b-cf13-45fb-bd8e-ca16e2643e65"
      }
    },
    "platforms": [
      "ios",
      "android"
    ]
  }
}
